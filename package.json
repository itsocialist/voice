{
  "name": "@itsocialist/voice",
  "version": "0.1.0",
  "description": "Multi-provider voice library for Next.js: ElevenLabs, Fish Audio, OpenAI TTS, Deepgram STT, and ElevenLabs ConvAI — with React hooks and drop-in route handlers",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./next": "./next/index.ts",
    "./react": "./react/index.ts"
  },
  "homepage": "https://github.com/itsocialist/voice",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsocialist/voice.git"
  },
  "bugs": {
    "url": "https://github.com/itsocialist/voice/issues"
  },
  "author": "itsocialist",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npx tsx scripts/check-providers.ts"
  },
  "keywords": [
    "voice", "tts", "stt", "text-to-speech", "speech-to-text",
    "elevenlabs", "fish-audio", "openai", "deepgram",
    "convai", "conversational-ai", "next.js", "react", "nextjs"
  ],
  "license": "MIT",
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@elevenlabs/client": "^0.15.2",
    "@elevenlabs/react": "^0.14.3"
  }
}
