{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@briandawson/voice": ["./src/index.ts"],
      "@briandawson/voice/next": ["./next/index.ts"],
      "@briandawson/voice/react": ["./react/index.ts"]
    }
  },
  "include": ["src/**/*", "next/**/*", "react/**/*"],
  "exclude": ["node_modules", "dist"]
}
