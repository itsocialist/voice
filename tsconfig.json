{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@itsocialist/voice": ["./src/index.ts"],
      "@itsocialist/voice/next": ["./next/index.ts"],
      "@itsocialist/voice/react": ["./react/index.ts"],
      "react": ["./node_modules/@types/react"]
    }
  },
  "include": ["src/**/*", "next/**/*", "react/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
