{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false
  },
  "include": ["src/**/*", "next/**/*", "react/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__", "scripts"]
}
